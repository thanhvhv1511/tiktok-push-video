# ==========================================
# CẤU HÌNH ĐƯỜNG DẪN HỆ THỐNG (MÔI TRƯỜNG MAC/LINUX)
# ==========================================

# 1. Đường dẫn chạy Google Chrome (Dùng nháy kép để bọc khoảng trắng)
CHROME_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"

# 2. Thư mục chứa Profile Data của Chrome
CHROME_DATA_DIR="/Users/thanhvhv/personal/tool/data-browser"

# 3. Đường dẫn thực thi PHP CLI (Thường là 'php', nhưng có thể trỏ tới file bin của MAMP/XAMPP nếu cần)
PHP_PATH="/opt/homebrew/bin/php"

# 4. Đường dẫn thực thi Node.js (PHP sẽ dùng đường dẫn này để gọi Bot)
NODE_PATH="node"
CUSTOM_BIN_PATH="/usr/local/bin:/opt/homebrew/bin"